---
import profilePic from "@/assets/c-arthur.webp";
import LinkButton from "./ui/link-button.astro";
---

<header class="flex w-full max-w-xl flex-col gap-12">
  <div class="flex items-center gap-4">
    <img
      src={profilePic.src}
      alt="Arthur Sallé"
      height={96}
      width={96}
      class="aspect-square size-16 rounded-full border-2 object-cover shadow-xs shadow-zinc-500 select-none md:size-20"
    />
    <div class="font-manrope">
      <h1 class="text-2xl font-medium text-zinc-100 md:text-3xl">
        Arthur Sallé
      </h1>
      <h2 class="text-zinc-500 md:text-lg">Fullstack Product Developer</h2>
    </div>
  </div>

  <div class="flex flex-col gap-6">
    <div class="flex flex-col gap-4">
      <p>
        I architect and build digital products end-to-end, from early-stage
        workshops to production-ready apps. Based in Angers, France, I work
        across web and mobile, from frontend to backend and infrastructure.
      </p>
      <p>
        Part of <a href="https://undefinedhq.com/" target="_blank" class="text-zinc-300 underline underline-offset-2 transition-colors duration-200 hover:text-white">UndefinedHQ</a>,
        a small collective where I collaborate with a designer and another
        developer to ship products that are both well-crafted and business-driven.
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <LinkButton href="https://github.com/ArthurSalle">Github</LinkButton>
      <LinkButton href="https://www.linkedin.com/in/arthur-sall%C3%A9/"
        >LinkedIn</LinkButton
      >
      <LinkButton href="https://x.com/arthrsll">Twitter</LinkButton>
    </div>
  </div>
</header>
