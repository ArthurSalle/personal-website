---
type Project = {
  title: string;
  description: string;
  imageUrl: ImageMetadata["src"];
  url?: string;
  bgClass?: string;
  imgClass?: string;
  isWip?: boolean;
};

type Props = {
  project: Project;
};

const { project }: Props = Astro.props;
---

<a
  href={project.url}
  target="_blank"
  rel="noopener noreferrer"
  class={`flex flex-col gap-2 ${project.url ? "cursor-pointer" : "cursor-default"}`}
>
  {
    !project.isWip ? (
      project.imageUrl ? (
        <div
          class={`flex h-44 items-center justify-center rounded-md ${project.bgClass || "bg-zinc-100"}`}
        >
          <img
            src={project.imageUrl}
            alt={project.title}
            class={`${project.imgClass || "h-32"} rounded-xs object-contain`}
            height="128"
            width="207"
          />
        </div>
      ) : (
        <div class="h-44 w-full rounded-md bg-zinc-100" />
      )
    ) : (
      <div
        class={`relative flex h-44 items-center justify-center rounded-md ${project.bgClass || "bg-zinc-100"}`}
      >
        {project.imageUrl && (
          <img
            src={project.imageUrl}
            alt={project.title}
            class="h-20 rounded-xs object-contain"
            height="80"
            width="130"
          />
        )}
        <span class="absolute right-2 bottom-2 rounded-full bg-amber-400 px-2.5 py-0.5 font-manrope text-xs font-semibold text-zinc-900">
          COMING SOON
        </span>
      </div>
    )
  }

  <div>
    <h3 class="font-manrope font-medium text-zinc-100">{project.title}</h3>
    <p class="text-sm text-zinc-400">
      {
        project.description
          ? project.description
          : "Lorem ipsum dolor sit amet consectetur, adipisicing elit. Veritatis incidunt fuga, sint officiis aspernatur."
      }
    </p>
  </div>
</a>
