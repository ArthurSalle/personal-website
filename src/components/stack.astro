---
import Badge from "./ui/badge.astro";

const labels = [
  "react",
  "typescript",
  "expo",
  "tanstack",
  "trpc",
  "hono",
  "drizzle",
  "postgresql",
  "neon",
  "convex",
  "railway",
  "vite",
  "astro",
  "tailwind",
];
---

<div class="flex w-full max-w-xl flex-col gap-4">
  <h2 class="font-manrope text-lg font-semibold text-zinc-100">Stack</h2>

  <div class="flex flex-wrap items-center gap-2 font-mono">
    {labels.map((label) => <Badge>{label}</Badge>)}
  </div>
</div>
